{
  "manifest_version": 3,
  "name": "YouTube Interval Pauser",
  "version": "1.4",
  "description": "Automatically pauses YouTube videos at a set interval and/or after each sentence in the captions.",
  "permissions": ["scripting", "tabs", "storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "48": "icon.png" }
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "icons": { "48": "icon.png" }
}
